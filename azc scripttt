local skyboxButton = Instance.new("TextButton")
skyboxButton.Name = "Skybox"
skyboxButton.Size = UDim2.new(0.4, 0, 0, 40)
skyboxButton.Position = UDim2.new(0.08, 0, 0.25, 0)
