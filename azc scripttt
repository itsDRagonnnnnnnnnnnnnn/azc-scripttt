local TweenService = game:GetService("TweenService")
local Players = game:GetService("Players")
local Lighting = game:GetService("Lighting")

-- 1. Get references to your UI elements
local menuFrame = script.Parent
local openButton = menuFrame:WaitForChild("OpenButton")
local minusButton = menuFrame:WaitForChild("MinusButton")

-- Ensure these match the names of your buttons in the Explorer!
local killAllButton = menuFrame:WaitForChild("KillAllButton") 
local skyboxButton = menuFrame:WaitForChild("SkyboxButton")

-- 2. Get reference to the frame you want to appear
local screenGui = menuFrame.Parent
local targetFrame = screenGui:WaitForChild("TargetFrame") 

-- 3. Set up the Animation Speed and Style
local tweenInfo = TweenInfo.new(0.5, Enum.EasingStyle.Quint, Enum.EasingDirection.Out)

-- 4. Define where the frame should go
local openPosition = {Position = UDim2.new(0.5, 0, 0.5, 0)} -- Center of the screen
local closePosition = {Position = UDim2.new(0.5, 0, 1.5, 0)} -- Off-screen (bottom)

local openTween = TweenService:Create(targetFrame, tweenInfo, openPosition)
local closeTween = TweenService:Create(targetFrame, tweenInfo, closePosition)

-- 5. Open Animation
openButton.MouseButton1Click:Connect(function()
	targetFrame.AnchorPoint = Vector2.new(0.5, 0.5) 
	targetFrame.Visible = true
	openTween:Play()
end)

-- 6. Close Animation
minusButton.MouseButton1Click:Connect(function()
	closeTween:Play()
	closeTween.Completed:Wait()
	targetFrame.Visible = false
end)

-- 7. Kill All Action
killAllButton.MouseButton1Click:Connect(function()
	for _, player in pairs(Players:GetPlayers()) do
		if player.Character then
			local humanoid = player.Character:FindFirstChildOfClass("Humanoid")
			if humanoid then
				humanoid.Health = 0
			end
		end
	end
	print("All players have been eliminated!")
end)

-- 8. Skybox Action
local newSkyboxImage = "rbxassetid://106237155086013" 

skyboxButton.MouseButton1Click:Connect(function()
	local sky = Lighting:FindFirstChildOfClass("Sky")
	
	if not sky then
		sky = Instance.new("Sky")
		sky.Parent = Lighting
	end

	sky.SkyboxBk = newSkyboxImage
	sky.SkyboxDn = newSkyboxImage
	sky.SkyboxFt = newSkyboxImage
	sky.SkyboxLf = newSkyboxImage
	sky.SkyboxRt = newSkyboxImage
	sky.SkyboxUp = newSkyboxImage

	print("Skybox changed for everyone!")
end)
