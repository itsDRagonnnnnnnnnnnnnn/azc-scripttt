local TweenService = game:GetService("TweenService")
local Players = game:GetService("Players")

-- Find your UI directly inside PlayerGui instead of using script.Parent
local localPlayer = Players.LocalPlayer
local playerGui = localPlayer:WaitForChild("PlayerGui")

-- 1. Locate your exact ScreenGui and Frames based on your image layout
-- Replace "ScreenGui" if your main UI folder has a custom name in Roblox Studio!
local screenGui = playerGui:WaitForChild("ScreenGui") 
local menuFrame = screenGui:WaitForChild("AZC script + -")
local targetFrame = screenGui:WaitForChild("AZC SCRIPTS") 

-- 2. Locate the buttons inside those frames
local openButton = menuFrame:WaitForChild("OpenButton")
local minusButton = menuFrame:WaitForChild("MinusButton")

-- 3. Set up the Animation Speed and Style
local tweenInfo = TweenInfo.new(0.5, Enum.EasingStyle.Quint, Enum.EasingDirection.Out)

-- 4. Define where the frame should go
local openPosition = {Position = UDim2.new(0.5, 0, 0.5, 0)} -- Center of the screen
local closePosition = {Position = UDim2.new(0.5, 0, 1.5, 0)} -- Off-screen (bottom)

-- Create the animations (Tweens)
local openTween = TweenService:Create(targetFrame, tweenInfo, openPosition)
local closeTween = TweenService:Create(targetFrame, tweenInfo, closePosition)

-- 5. Make the + button play the Open animation
openButton.MouseButton1Click:Connect(function()
	targetFrame.AnchorPoint = Vector2.new(0.5, 0.5) 
	targetFrame.Visible = true
	openTween:Play()
end)

-- 6. Make the - button play the Close animation
minusButton.MouseButton1Click:Connect(function()
	closeTween:Play()

	-- Wait for the animation to finish before making it invisible
	closeTween.Completed:Wait()
	targetFrame.Visible = false
end)
